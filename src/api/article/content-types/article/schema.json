{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "seo_matadata": {
      "type": "component",
      "component": "article.seo-matadata",
      "repeatable": false
    },
    "header": {
      "type": "component",
      "component": "article.header",
      "repeatable": false
    },
    "cover": {
      "type": "component",
      "component": "article.cover-info",
      "repeatable": false
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "articles"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "articles"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "articles"
    },
    "cta": {
      "type": "component",
      "component": "article.cta",
      "repeatable": false
    },
    "stickyToc": {
      "type": "boolean"
    },
    "share_config": {
      "type": "component",
      "component": "article.share-config",
      "repeatable": false
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "article.article-content"
      ],
      "required": true
    },
    "related_config": {
      "type": "component",
      "component": "article.related-config",
      "repeatable": false
    }
  }
}
