{
  "kind": "collectionType",
  "collectionName": "pseo_items",
  "info": {
    "singularName": "pseo-item",
    "pluralName": "pseo-items",
    "displayName": "PSEO-Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "slug": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "unique": true,
      "regex": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "html_body": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "sort_order": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": false,
      "default": 0
    },
    "card_title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "card_subtitle": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "card_description": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "maxLength": 120,
      "required": true
    },
    "card_image": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "card_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::pseo-landing-item-category.pseo-landing-item-category",
      "inversedBy": "pseo_items"
    },
    "card_tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::pseo-card-tag.pseo-card-tag",
      "mappedBy": "pseo_items"
    },
    "landing": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::pseo-landind.pseo-landind",
      "inversedBy": "pseo_items"
    },
    "preview_url": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "external_url": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "publish_time": {
      "type": "datetime",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    }
  }
}
